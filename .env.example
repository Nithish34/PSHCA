# Copy this file to .env and fill in your actual values
#
# ── Hackathon Validator (Phase 2) ──────────────────────────────────────────────
# The validator injects these three variables automatically.
# Your code must use API_BASE_URL and API_KEY to reach the LiteLLM proxy.
#
# API_BASE_URL=<injected by hackathon>
# API_KEY=<injected by hackathon>
# MODEL_NAME=<injected by hackathon>

# ── Local Development Fallback ─────────────────────────────────────────────────
# When running locally (outside the hackathon environment), you can set
# HF_TOKEN instead of API_KEY. The code checks API_KEY first, then HF_TOKEN.

# Hugging Face Inference API base URL (used locally)
API_BASE_URL="https://router.huggingface.co/v1"

# Your Hugging Face API Token (local dev only — hackathon uses API_KEY instead)
# Get it from: https://huggingface.co/settings/tokens
HF_TOKEN="hf_your_token_here"

# Model to use for inference
# Recommended (free HF Inference API): meta-llama/Llama-3.3-70B-Instruct
# Alternatives: Qwen/Qwen2.5-72B-Instruct, mistralai/Mistral-7B-Instruct-v0.3
MODEL_NAME="meta-llama/Llama-3.3-70B-Instruct"
