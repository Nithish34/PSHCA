# Copy this file to .env and fill in your actual values

# Hugging Face API Base URL
API_BASE_URL="https://api-inference.huggingface.co/v1"

# Your Hugging Face API Token
# Get it from: https://huggingface.co/settings/tokens
HF_TOKEN="hf_your_token_here"

# Model to use for inference (must be available on your HF account / Inference API)
# Recommended (free HF Inference API): meta-llama/Llama-3.3-70B-Instruct
# Alternatives: Qwen/Qwen2.5-72B-Instruct, mistralai/Mistral-7B-Instruct-v0.3
# OpenAI-compatible endpoint: gpt-4o-mini, gpt-4o
MODEL_NAME="meta-llama/Llama-3.3-70B-Instruct"
